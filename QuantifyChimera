import os

configfile: "config.yaml"

samples = config["samples"]
custom_gtf = config["custom_gtf"]
ref_gtf = config["ref_gtf"]
ref_fasta = config["ref_fasta"]
outdir = config["outdir"]

merged_gtf = os.path.join(outdir, "merged.gtf")
merged_fasta = os.path.join("protein_transcriptome.fa")
salmon_index_dir = os.path.join(outdir, "salmon_index")
star_index_dir = os.path.join(outdir, "star_index")

rule all:
    input:
        expand(os.path.join(outdir, "salmon_protein", "{sample}", "ok"),
               sample=samples)

# --- GTF merging ---
rule merge_gtf:
    input:
        custom=custom_gtf,
        reference=ref_gtf
    output:
        merged=merged_gtf
    shell:
        "cat {input.reference} {input.custom} > {output.merged}"

# --- Transcriptome FASTA ---
rule generate_transcriptome_fasta:
    conda: "env/gffread.yaml"
    input:
        gtf=merged_gtf,
        fasta=ref_fasta
    output:
        fasta=merged_fasta
    shell:
        "gffread {input.gtf} -g {input.fasta} -w {output.fasta}"

# --- Salmon index ---
rule build_salmon_index:
    conda: "env/salmon.yaml"
    input:
        fasta=merged_fasta
    output:
        directory(salmon_index_dir)
    threads: 4
    shell:
        "salmon index -t {input.fasta} -i {output} -p {threads}"

# --- STAR genome index ---
rule build_star_index:
    conda: "env/star.yaml"
    input:
        fasta=ref_fasta,
        gtf=merged_gtf
    output:
        directory(star_index_dir)
    threads: 8
    resources:
        mem_mb=64000
    shell:
        """
        STAR --runThreadN {threads} \
             --runMode genomeGenerate \
             --genomeDir {output} \
             --genomeFastaFiles {input.fasta} \
             --sjdbGTFfile {input.gtf} \
             --sjdbOverhang 100
        """

# --- Trimming ---
rule trim_reads:
    conda: "env/fastp.yaml"
    input:
        r1=lambda wc: samples[wc.sample]["R1"],
        r2=lambda wc: samples[wc.sample]["R2"]
    output:
        r1=temp(os.path.join(outdir, "trimmed", "{sample}_R1.trimmed.fastq.gz")),
        r2=temp(os.path.join(outdir, "trimmed", "{sample}_R2.trimmed.fastq.gz")),
        html=os.path.join(outdir, "trimmed", "{sample}.fastp.html"),
        json=os.path.join(outdir, "trimmed", "{sample}.fastp.json")
    threads: 4
    shell:
        """
        fastp -i {input.r1} -I {input.r2} \
              -o {output.r1} -O {output.r2} \
              -h {output.html} -j {output.json} \
              -w {threads}
        """

# --- STAR two-pass mapping ---
rule star_two_pass:
    conda: "env/star.yaml"
    input:
        index=star_index_dir,
        r1=lambda wc: os.path.join(outdir, "trimmed", f"{wc.sample}_R1.trimmed.fastq.gz"),
        r2=lambda wc: os.path.join(outdir, "trimmed", f"{wc.sample}_R2.trimmed.fastq.gz")
    output:
        bam=os.path.join(outdir, "star", "{sample}", "Aligned.sortedByCoord.out.bam")
    resources:
        mem_mb=128000
    threads: 4
    params:
        outprefix=lambda wc: os.path.join(outdir, "star", wc.sample, "")
    shell:
        """
        STAR --runThreadN {threads} \
             --genomeDir {input.index} \
             --readFilesIn {input.r1} {input.r2} \
             --readFilesCommand zcat \
             --twopassMode Basic \
             --outSAMtype BAM SortedByCoordinate \
             --outFileNamePrefix {params.outprefix} \
             --limitBAMsortRAM 60000000000
        """

# --- Salmon quant ---
rule salmon_quant:
    conda: "env/salmon.yaml"
    input:
        index=salmon_index_dir,
        r1=lambda wc: os.path.join(outdir, "trimmed", f"{wc.sample}_R1.trimmed.fastq.gz"),
        r2=lambda wc: os.path.join(outdir, "trimmed", f"{wc.sample}_R2.trimmed.fastq.gz")
    output:
        quant=os.path.join(outdir, "salmon_protein", "{sample}", "quant.sf"),
        ok=os.path.join(outdir, "salmon_protein", "{sample}", "ok")
    threads: 8
    shell:
        """
        salmon quant -i {input.index} \
                     -l A -1 {input.r1} -2 {input.r2} \
                     -p {threads} -o $(dirname {output.quant})
        touch {output.ok}
        """
